# PulseID Environment Configuration
# Copy this file to .env and update the values

# ── Database ──────────────────────────────────
# Use a strong password (min 16 chars recommended)
POSTGRES_PASSWORD=pulseid_secret

# ── Security ─────────────────────────────────
# JWT signing key — MUST be at least 32 chars for HS256. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
PULSEID_SECRET_KEY=039a7fb33ee26b726e7071a27a00d20eeb9a3bc3005d06025ecb7f1414b7894e

# API key for backend access (nginx injects this). Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
PULSEID_API_KEY=634a531e74af30bef4f8e64648f2f4f680f0667c8196213d9c862c0db8460b02

# ── Admin account ────────────────────────────
PULSEID_USERNAME=admin
PULSEID_PASSWORD=your-secret-password

# NFC reader filter (substring of reader name, e.g. "ACR122U")
PULSEID_READER_FILTER=

# ── Company info (for PDF reports) ────────────
COMPANY_NAME=Company Name
COMPANY_STREET=Company Address
COMPANY_CITY=Company City
COMPANY_ZIP=00000
COMPANY_COUNTRY=Country
COMPANY_PHONE=+1 234 567 8900
COMPANY_EMAIL=info@company.com

# Path to company logo file (inside backend container)
LOGO_PATH=
