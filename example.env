# PulseID Environment Configuration
# Copy this file to .env and update the values

# ── Database ──────────────────────────────────
POSTGRES_PASSWORD=pulseid_secret

# ── Backend ───────────────────────────────────
PULSEID_API_KEY=change-me-in-production
PULSEID_SECRET_KEY=change-me-in-production
PULSEID_USERNAME=admin
PULSEID_PASSWORD=your-secret-password

# NFC reader filter (substring of reader name, e.g. "ACR122U")
PULSEID_READER_FILTER=

# ── Company info (for PDF reports) ────────────
COMPANY_NAME=Company Name
COMPANY_STREET=Company Address
COMPANY_CITY=Company City
COMPANY_ZIP=00000
COMPANY_COUNTRY=Country
COMPANY_PHONE=+1 234 567 8900
COMPANY_EMAIL=info@company.com

# Path to company logo file (inside backend container)
LOGO_PATH=
